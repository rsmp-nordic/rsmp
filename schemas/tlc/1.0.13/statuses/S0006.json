{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Emergency stage.\nThe status is active during emergency prioritization.\nUsed in situations where full priority is given in the emergency vehicle program.",
  "properties" : {
    "n" : {
      "enum" : [
        "emergencystage",
        "status"
      ]
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/q_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "status"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "False: Emergency stage inactive\nTrue: Emergency stage active",
              "type" : "boolean"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "emergencystage"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Number of emergency stage",
              "type" : "integer"
            }
          }
        }
      }
    ]
  }
}
