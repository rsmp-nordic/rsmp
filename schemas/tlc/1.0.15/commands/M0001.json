{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Sets functional position.\nSets the controller to yellow flash, dark mode or normal control.\nRequires security code 2.",
  "properties" : {
    "n" : {
      "enum" : [
        "intersection",
        "securityCode",
        "status",
        "timeout"
      ]
    },
    "cO" : {
      "const" : "setValue"
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/age_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "status"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Set operating mode",
              "type" : "string",
              "enum" : [
                "Dark",
                "NormalControl",
                "YellowFlash"
              ]
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "securityCode"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Security code 2",
              "$ref" : "../defs/definitions.json#/string_list"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "timeout"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Time in minutes until controller automatically reverts to previous functional position.\n0=no automatic return",
              "$ref" : "../defs/definitions.json#/integer_list"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "intersection"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Intersection number",
              "$ref" : "../defs/definitions.json#/integer_list"
            }
          }
        }
      }
    ]
  }
}
