{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Less serious lamp error.\nUsed for lamp errors.\nIs a \"minor fault\" defined according to 3.11 in EN12675.",
  "properties" : {
    "n" : {
      "enum" : [
        "color"
      ]
    }
  },
  "allOf" : [
    {
      "if" : {
        "properties" : {
          "n" : {
            "const" : "color"
          }
        }
      },
      "then" : {
        "properties" : {
          "v" : {
            "description" : "Color of lamp",
            "type" : "string",
            "enum" : [
              "green",
              "red",
              "yellow"
            ]
          }
        }
      }
    }
  ]
}
