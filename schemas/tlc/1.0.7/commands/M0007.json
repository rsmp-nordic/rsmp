{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Activate fixed time control.\nDeactivates the traffic actuated control using detectors and activates pre-timed control.\nCan be used in case normal detectors can't be used, e.g. during maintenance work.\nRequires security code 2.",
  "properties" : {
    "n" : {
      "enum" : [
        "securityCode",
        "status"
      ]
    },
    "cO" : {
      "const" : "setFixedTime"
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/age_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "status"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "False: Deactivate fixed time control\nTrue: Activate fixed time control",
              "type" : "boolean"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "securityCode"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Security code 2",
              "type" : "string"
            }
          }
        }
      }
    ]
  }
}
