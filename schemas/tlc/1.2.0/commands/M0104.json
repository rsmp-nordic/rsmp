{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Set clock.\nCan be used to manually set the clock of the traffic light controller if automatic  time synchronization (NTP or watchdog sync) is not available. For instance, during maintenance work.\nNote: UTC is used.\nRequires security code 1",
  "properties" : {
    "n" : {
      "enum" : [
        "day",
        "hour",
        "minute",
        "month",
        "second",
        "securityCode",
        "year"
      ]
    },
    "cO" : {
      "const" : "setDate"
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/age_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "securityCode"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Security code 1",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "year"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Year",
              "type" : "integer"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "month"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Month",
              "type" : "integer"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "day"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Day of month",
              "type" : "integer"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "hour"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Hour",
              "type" : "integer"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "minute"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Minute",
              "type" : "integer"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "second"
            }
          }
        },
        "then" : {
          "properties" : {
            "v" : {
              "description" : "Second",
              "type" : "integer"
            }
          }
        }
      }
    ]
  }
}
