{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Traffic Counting: Number of vehicles.\nUsed for Traffic counting.",
  "properties" : {
    "n" : {
      "enum" : [
        "starttime",
        "vehicles"
      ]
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/q_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "starttime"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Time stamp for start of measuring",
              "$ref" : "../defs/definitions.json#/timestamp"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "vehicles"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Number of vehicles on a given detector logic (since last update)",
              "$ref" : "../defs/definitions.json#/integer"
            }
          }
        }
      }
    ]
  }
}
