{
  "rsmp_string": {
    "type" : "string",
    "not" : {
      "$comment" : "A unicode string, excluding ASCII control characters and Unicode line/paragraph separators",
      "type" : "string",
      "pattern" : "[\\u0000-\\u001F\\u007F\\u2028\\u2029]"
    }
  },
  "message_id": {
    "description" : "Message Id",
    "$comment" : "Example: 1.2.3 or 1.2",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern": "^[a-fA-F0-9]{8}-[a-fA-F0-9]{4}-4[a-fA-F0-9]{3}-[89abAB][a-fA-F0-9]{3}-[a-fA-F0-9]{12}$" }
    ]
  },
  "timestamp" : {
    "description" : "Timestamp",
    "$comment" : "Example: 2015-06-08T11:49:03.293Z",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" }
    ]
  },
  "integer" : {
    "description" : "Integer as string",
    "$comment" : "Example: 123 or -123",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern": "^\\-?[0-9]+$" }
    ]
  },
  "version": {
    "description" : "Version",
    "$comment" : "Example: 1.2.3 or 1.2",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^[0-9]{1,2}\\.[0-9]{1,2}(\\.[0-9]{1,2})?" }
    ]
  },
  "command_code": {
    "description" : "Command code id",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^M" }
    ]
  },
  "status_code": {
    "description" : "Status code id",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^S" }
    ]
  },
  "alarm_code": {
    "description" : "Alarm code id",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^A" }
    ]
  },
  "component_id": {
    "description" : "Compoment id",
    "allOf" : [
      { "$ref" : "#/rsmp_string" }
    ]
  },
  "component_type": {
    "description" : "Component type",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^[A-Za-z0-9_-]+(?:/[A-Za-z0-9_-]+)*$" }
    ]
  },
  "component_name": {
    "description" : "Component name",
    "minLength" : 1,
    "allOf" : [
      { "$ref" : "#/rsmp_string" }
    ]
  },
  "sxl_name": {
    "description" : "SXL name",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^[A-Za-z0-9_-]+(?:/[A-Za-z0-9_-]+)*$" }
    ]
  },
  "sxl_prefix": {
    "description" : "SXL prefix",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^[A-Za-z0-9_-]+/$" }
    ]
  },
  "boolean": {
    "description" : "Boolean as string",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "enum" : [ "True", "False" ] }
    ]
  },
  "integer_list": {
    "description" : "Comma-separated list of integers as strings",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^(\\-?\\d+)(?:,(\\-?\\d+))*$" }
    ]
  },
  "number_list": {
    "description" : "Comma-separated list of numbers as strings",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^(\\-?\\d+(\\.\\d+)?)(?:,(\\-?\\d+(\\.\\d+)?))*$" }
    ]
  },
  "boolean_list": {
    "description" : "Comma-separated list of booleans as strings",
    "allOf" : [
      { "$ref" : "#/rsmp_string" },
      { "pattern" : "^(True|False)(?:,(True|False))*$" }
    ]
  },
  "string_list": {
    "description" : "Comma-separated list of strings",
    "allOf" : [
      { "$ref" : "#/rsmp_string" }
    ]
  }
}


