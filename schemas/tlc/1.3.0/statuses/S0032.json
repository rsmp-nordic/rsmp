{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Coordinated control\nThis status is used when coordination between traffic light controllers is active. Coordination is described in detail in the corresponding section\nPlease note that all values in this status uses comma-separated lists - one value for each intersection, e.g. \u201c1,2\u201d and \u201ccentralized,off\u201d",
  "properties" : {
    "n" : {
      "enum" : [
        "intersection",
        "source",
        "status"
      ]
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/q_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "intersection"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Comma separated list of intersections which the status relates to, e.g. \u201c1,2\u201d.\nUse \u201c0\u201d for all intersections of the TLC.",
              "$ref" : "../defs/definitions.json#/integer_list"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "status"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "$ref" : "../defs/definitions.json#/string_list",
              "pattern" : "(?-mix:^(local|centralized|off)(?:,(local|centralized|off))*$)"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "source"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Source of the status change",
              "$ref" : "../defs/definitions.json#/string_list",
              "pattern" : "(?-mix:^(operator_panel|calendar_clock|control_block|forced|startup|other)(?:,(operator_panel|calendar_clock|control_block|forced|startup|other))*$)"
            }
          }
        }
      }
    ]
  }
}
