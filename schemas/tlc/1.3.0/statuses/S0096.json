{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Current date and time.\nNote: UTC is used.\nProvides diagnostic information about the current date and time set in the controller.",
  "properties" : {
    "n" : {
      "enum" : [
        "day",
        "hour",
        "minute",
        "month",
        "second",
        "year"
      ]
    }
  },
  "if" : {
    "$ref" : "../defs/guards.json#/$defs/q_unknown_or_undefined"
  },
  "then" : {},
  "else" : {
    "allOf" : [
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "year"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Year",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "month"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Month",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "day"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Day of month",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "hour"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Hour",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "minute"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Minute",
              "type" : "string"
            }
          }
        }
      },
      {
        "if" : {
          "properties" : {
            "n" : {
              "const" : "second"
            }
          }
        },
        "then" : {
          "properties" : {
            "s" : {
              "description" : "Second",
              "type" : "string"
            }
          }
        }
      }
    ]
  }
}
