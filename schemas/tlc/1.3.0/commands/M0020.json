{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "description" : "Force output.\nForce a given output (1-255) of the controllers general purpose I/O to either True of False. Can be used for all types of output where the traffic light controller needs to control other equipment.\nCan be used for bus priority, coordination between traffic controllers, external control systems, and much more.\nWhen the output is released (status=False), the outputValue is ignored.\nRequires security code 2.",
  "properties" : {
    "n" : {
      "enum" : [
        "output",
        "outputValue",
        "securityCode",
        "status"
      ]
    },
    "cO" : {
      "const" : "setOutput"
    }
  },
  "allOf" : [
    {
      "if" : {
        "properties" : {
          "n" : {
            "const" : "status"
          }
        }
      },
      "then" : {
        "properties" : {
          "v" : {
            "description" : "True: Force output\nFalse: Release output",
            "type" : "string"
          }
        }
      }
    },
    {
      "if" : {
        "properties" : {
          "n" : {
            "const" : "securityCode"
          }
        }
      },
      "then" : {
        "properties" : {
          "v" : {
            "description" : "Security code 2",
            "type" : "string"
          }
        }
      }
    },
    {
      "if" : {
        "properties" : {
          "n" : {
            "const" : "output"
          }
        }
      },
      "then" : {
        "properties" : {
          "v" : {
            "description" : "Number of Output",
            "type" : "string"
          }
        }
      }
    },
    {
      "if" : {
        "properties" : {
          "n" : {
            "const" : "outputValue"
          }
        }
      },
      "then" : {
        "properties" : {
          "v" : {
            "description" : "False: output forced off\nTrue: output forced on",
            "type" : "string"
          }
        }
      }
    }
  ]
}
