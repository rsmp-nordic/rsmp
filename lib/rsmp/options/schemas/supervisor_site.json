{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supervisor_site.json",
  "type": "object",
  "properties": {
    "sxls": {
      "type": "object",
      "propertyNames": { "not": { "const": "core" } },
      "additionalProperties": { "type": "string" }
    },
    "core_version": { "type": "string" },
    "rsmp_versions": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "type": { "type": "string" },
    "components": { "type": "object" },
    "supervisors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ip": { "type": "string" },
          "port": { "type": ["integer", "string"] }
        },
        "required": ["ip", "port"],
        "additionalProperties": true
      }
    },
    "intervals": {
      "type": "object",
      "properties": {
        "timer": { "type": "number" },
        "watchdog": { "type": "number" },
        "reconnect": { "type": "number" },
        "after_connect": { "type": "number" }
      },
      "additionalProperties": true
    },
    "timeouts": {
      "type": "object",
      "properties": {
        "connect": { "type": "number" },
        "watchdog": { "type": "number" },
        "acknowledgement": { "type": "number" }
      },
      "additionalProperties": true
    },
    "send_after_connect": { "type": "boolean" },
    "receive_alarms": { "type": "boolean" },
    "message_buffer": {
      "type": "object",
      "properties": {
        "max_messages": { "type": "integer", "minimum": 1 },
        "statuses": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "cId": { "type": "string" },
                  "sCI": { "type": "string" },
                  "n": { "type": "string" }
                },
                "required": ["sCI"],
                "additionalProperties": false
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "skip_validation": { "type": "array", "items": { "type": "string" } },
    "security_codes": { "type": "object" },
    "startup_sequence": { "type": "string" },
    "signal_plans": { "type": "object" },
    "inputs": { "type": "object" },
    "live_output": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
